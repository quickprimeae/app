# ============================================================
# QuickPrime Environment Variables
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to Git.
# ============================================================

# Supabase — get from: supabase.com > Settings > API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...your-anon-key...
SUPABASE_SERVICE_ROLE_KEY=eyJ...your-service-role-key...

# App URL — change to https://app.quickprime.ae in production
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Twilio WhatsApp — get from: twilio.com > Console
TWILIO_ACCOUNT_SID=AC...
TWILIO_AUTH_TOKEN=...
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# AWS Rekognition — for face match
AWS_ACCESS_KEY_ID=...
AWS_SECRET_ACCESS_KEY=...
AWS_REGION=ap-south-1
AWS_S3_BUCKET=quickprime-selfies

# PIN setup link secret — generate with: openssl rand -hex 32
PIN_SETUP_SECRET=your-random-secret-here

# Google Maps — get from: console.cloud.google.com > APIs & Services > Credentials
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=AIza...your-maps-key...
